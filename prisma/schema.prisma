generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id               String    @id @default(cuid())
  name             String
  phoneNumber      String    @unique
  bloodGroup       String
  address          String
  gender           String
  lastDonationDate DateTime?
  password         String
  profileImage     String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}